# Server
PORT=4000
NODE_ENV=development

# Mongo
MONGODB_URI=mongodb://127.0.0.1:27017/devaicon

# Session — must be >= 32 chars
SESSION_SECRET=replace-with-a-long-random-string-min-32-chars

# Allowed origin(s) for the Next.js client (comma-separated)
CLIENT_ORIGIN=http://localhost:3000

# Optional: seed users from these vars when running `npm run seed`.
# Pattern: {USERNAME}_PASSWORD=... — usernames starting with "admin" become admins.
# Example:
# DEV1_PASSWORD=changeme
# ADMIN1_PASSWORD=changeme
